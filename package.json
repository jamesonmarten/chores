    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@stripe/stripe-js": "^9.4.0"
  }
