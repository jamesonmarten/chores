{
  "name": "family-chores-more",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "cap init 'Family Chores' com.devcabin.familychores --web-dir dist",
