{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/",        "destination": "/landing.html" },
    { "source": "/app",     "destination": "/index.html" },
    { "source": "/app/(.*)","destination": "/index.html" },
    { "source": "/demo",    "destination": "/demo.html" },
    { "source": "/(.*)",    "destination": "/index.html" }
  ]
}
