# Copy this file to .env.local for local Vite dev (`npm run dev`).
# For Vercel Functions (`vercel dev` or production), set these in the Vercel dashboard.

# ── Server-side (Vercel Functions) — set in Vercel dashboard, NOT here ──
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID=price_xxx              # OR STRIPE_PRODUCT_ID=prod_xxx
# CLIENT_URL=https://chores.devcabin.tech
# KV_REST_API_URL=...                    # auto-injected when you add Vercel KV
# KV_REST_API_TOKEN=...                  # auto-injected when you add Vercel KV

# ── Client-side (Vite, embedded at build time) ──
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# Leave VITE_API_URL UNSET in production — client uses same-origin /api on chores.devcabin.tech.
# Only set when pointing the iOS app at a remote API:
# VITE_API_URL=https://chores.devcabin.tech/api
