# Copy this file to .env and fill in your real keys from https://dashboard.stripe.com
# Server-side (never exposed to browser)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID=your_stripe_price_id_here   # price_xxx from Stripe Dashboard → Products

# Client-side (embedded by Vite at build time — VITE_ prefix required)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
VITE_API_URL=https://chores.devcabin.tech

# Server
CLIENT_URL=https://chores.devcabin.tech
PORT=4242
